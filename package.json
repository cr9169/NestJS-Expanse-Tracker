{
  "name": "expense-tracker-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:shared": "npm run build --workspace=packages/shared",
    "dev": "concurrently \"npm run dev --workspace=apps/gateway\" \"npm run dev --workspace=apps/expenses-service\"",
    "dev:gateway": "npm run dev --workspace=apps/gateway",
    "dev:expenses": "npm run dev --workspace=apps/expenses-service",
    "lint": "eslint \"apps/**/*.ts\" \"packages/**/*.ts\" --ext .ts",
    "lint:fix": "eslint \"apps/**/*.ts\" \"packages/**/*.ts\" --ext .ts --fix",
    "format": "prettier --write \"apps/**/*.ts\" \"packages/**/*.ts\"",
    "format:check": "prettier --check \"apps/**/*.ts\" \"packages/**/*.ts\"",
    "clean": "rimraf apps/*/dist packages/*/dist apps/*/node_modules packages/*/node_modules node_modules",
    "docker:up": "docker-compose up --build",
    "docker:down": "docker-compose down -v"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.29.0",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
