{
  "//": [
    "auth-service — NestJS microservice responsible for user identity and authentication.",
    "Communicates with the gateway exclusively over TCP using NestJS MessagePatterns.",
    "Owns the SQLite database (via better-sqlite3) with user accounts and JWT token issuance.",
    "NOT exposed to the internet directly — only the gateway talks to it."
  ],
  "name": "@app/auth-service",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/main.ts",
    "start": "node -r tsconfig-paths/register dist/main.js",
    "lint": "eslint \"{src}/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/microservices": "^10.3.0",
    "@nestjs/swagger": "^7.3.0",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "joi": "^17.12.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
