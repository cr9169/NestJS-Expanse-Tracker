    "amqplib": "^0.10.0",
    "better-sqlite3": "^12.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "joi": "^17.12.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^9.0.0"
  },

  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.11.0",
