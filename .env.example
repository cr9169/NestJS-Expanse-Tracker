# Copy the matching file to `.env` inside the same app directory before running locally:
#   cp apps/gateway/.env.example apps/gateway/.env
#   cp apps/expenses-service/.env.example apps/expenses-service/.env
#   (and likewise for budget-, analytics-, notification-service)
#
# JWT_SECRET in gateway and auth-service must match (min 32 characters).
# `.env` is gitignored; `.env.example` is the committed template.
