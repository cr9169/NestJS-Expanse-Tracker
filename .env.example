# ─────────────────────────────────────────────
# GATEWAY (apps/gateway)
# ─────────────────────────────────────────────

# HTTP port the gateway listens on
GATEWAY_PORT=3000

# JWT secret for signing access tokens (min 32 chars, use a random secret in prod)
JWT_SECRET=change-me-to-a-long-random-secret-in-production

# How long access tokens are valid (ms format: 15m, 1h, etc.)
JWT_EXPIRATION=15m

# How long refresh tokens are valid
JWT_REFRESH_EXPIRATION=7d

# ─────────────────────────────────────────────
# EXPENSES SERVICE (apps/expenses-service)
# ─────────────────────────────────────────────

# Internal TCP port for microservice communication (not exposed externally)
TCP_PORT=3001

# Same JWT_SECRET — must match gateway for token verification
JWT_SECRET=change-me-to-a-long-random-secret-in-production

# Separate secret for refresh tokens
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-secret

# Path to SQLite database file (mounted as a Docker volume in production)
SQLITE_PATH=/data/expenses.db

# ─────────────────────────────────────────────
# GATEWAY → SERVICE COMMUNICATION
# ─────────────────────────────────────────────

# Host of the expenses-service TCP server (use 'expenses-service' in Docker)
TCP_HOST=localhost

# ─────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────

# Time window in milliseconds
THROTTLE_TTL=60000

# Max requests per window per IP
THROTTLE_LIMIT=10
